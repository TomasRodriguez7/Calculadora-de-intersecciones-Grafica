      <widget class="QWidget" name="pageIngresoDatos">
       <property name="styleSheet">
        <string notr="true">#pageIngresoDatos {
    border-image: url(:/prefix1/fondodatos.jpg) 0 0 0 0 stretch stretch;
}

#labelTitulo {
    color: #FFD700;
    font-size: 28px;
    font-weight: bold;
    background: transparent;
}
QLineEdit {
    background-color: white;
    color: black;
    border: 4px solid #555;
    border-radius: 10px;
    padding: 6px;
    selection-background-color: darkgray;
}
QPushButton {
    background-color: #d1d1d1;
    border: 6px solid #333;
    border-radius: 10px;
    padding: 10px;
    font-weight: bold;
    color: black;
}
#botonCalcular {
    background-color: #3498db;
    color: white;
    border: 2px solid #2980b9;
    border-radius: 8px;
    padding: 10px;
    font-size: 28px;
}

#botonCalcular:hover {
    background-color: #2980b9;
}

QLabel {
    color: white;
    font-weight: bold;
    font-size: 22px;
    background: transparent; 
}</string>
